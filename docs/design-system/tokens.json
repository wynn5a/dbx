{
  "$name": "Data Buddy Design System",
  "$version": "1.1.0",
  "color": {
    "surface": {
      "base":     { "value": "#08090a", "css": "--bg-base" },
      "canvas":   { "value": "#0b0c0e", "css": "--bg-canvas" },
      "panel":    { "value": "#0f1011", "css": "--bg-panel" },
      "elevated": { "value": "#16171a", "css": "--bg-elevated" },
      "input":    { "value": "#191a1e", "css": "--bg-input" },
      "hover":    { "value": "rgba(255,255,255,0.035)", "css": "--bg-hover" },
      "active":   { "value": "rgba(255,255,255,0.06)",  "css": "--bg-active" }
    },
    "border": {
      "soft":   { "value": "rgba(255,255,255,0.045)", "css": "--border-soft" },
      "base":   { "value": "rgba(255,255,255,0.07)",  "css": "--border" },
      "strong": { "value": "rgba(255,255,255,0.12)",  "css": "--border-strong" }
    },
    "text": {
      "primary":      { "value": "#f7f8f8", "css": "--text-1" },
      "secondary":    { "value": "#9c9da7", "css": "--text-2" },
      "tertiary":     { "value": "#6b6d79", "css": "--text-3" },
      "quaternary":   { "value": "#4c4e5a", "css": "--text-4" }
    },
    "accent": {
      "base": { "value": "#6e79d6", "css": "--accent", "tweakable": true },
      "soft": { "value": "rgba(110,121,214,0.16)", "css": "--accent-soft", "derived": "accent @ 16%" },
      "line": { "value": "rgba(110,121,214,0.45)", "css": "--accent-line", "derived": "accent @ 45%" }
    },
    "semantic": {
      "green":  { "value": "#3fb950", "css": "--green" },
      "amber":  { "value": "#d9a521", "css": "--amber" },
      "red":    { "value": "#e5534b", "css": "--red" },
      "blue":   { "value": "#4f9be6", "css": "--blue" },
      "purple": { "value": "#a371e8", "css": "--purple" },
      "teal":   { "value": "#2dd4bf", "css": "--teal" }
    },
    "dataType": {
      "int":  { "value": "#4f9be6", "css": "--t-int" },
      "text": { "value": "#3fb950", "css": "--t-text" },
      "time": { "value": "#d9a521", "css": "--t-time" },
      "bool": { "value": "#a371e8", "css": "--t-bool" },
      "json": { "value": "#e07a5f", "css": "--t-json" },
      "uuid": { "value": "#2dd4bf", "css": "--t-uuid" }
    }
  },
  "radius": {
    "inline":  { "value": "4px" },
    "sm":      { "value": "6px",  "css": "--radius-sm" },
    "base":    { "value": "8px",  "css": "--radius", "tweakable": "0–14px" },
    "overlay": { "value": "12px" },
    "pill":    { "value": "99px", "css": "--radius-pill" }
  },
  "size": {
    "rowCompact":  { "value": "30px" },
    "rowRegular":  { "value": "34px", "css": "--row-h", "tweakable": "density" },
    "rowComfy":    { "value": "42px" },
    "sidebar":     { "value": "256px", "css": "--sidebar-w", "tweakable": "210–320px" },
    "inspector":   { "value": "360px" },
    "topbar":      { "value": "44px" },
    "toolbar":     { "value": "38px" },
    "iconButton":  { "value": "28px" },
    "palette":     { "value": "560px" }
  },
  "font": {
    "ui":   { "value": "'Inter', system-ui, sans-serif", "css": "--font", "tweakable": ["Inter", "IBM Plex Sans", "System"] },
    "mono": { "value": "'IBM Plex Mono', ui-monospace, 'SF Mono', monospace", "css": "--mono" },
    "scale": {
      "display": "22px/600", "title": "19px/600", "subject": "16px/600",
      "body": "13px/450", "ui": "13.5px/500", "control": "12.5px/500",
      "caption": "11.5px/500", "label": "11px/600 upper", "micro": "10.5px mono"
    }
  },
  "shadow": {
    "card": { "value": "0 1px 2px rgba(0,0,0,0.25)", "css": "--shadow-card" },
    "pop":  { "value": "0 16px 48px -12px rgba(0,0,0,0.65), 0 4px 12px -2px rgba(0,0,0,0.45), 0 0 0 0.5px rgba(255,255,255,0.06)", "css": "--shadow-pop" },
    "sheen": { "value": "inset 0 1px 0 rgba(255,255,255,0.07)", "css": "--sheen", "note": "top highlight on raised elements" }
  },
  "motion": {
    "speed": { "value": "120ms", "css": "--speed" },
    "ease":  { "value": "cubic-bezier(0.25, 0.46, 0.45, 0.94)", "css": "--ease" }
  }
}
